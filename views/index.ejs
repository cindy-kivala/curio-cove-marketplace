<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <title>CurioCove - Marketplace</title>
    <link rel="stylesheet" href="/css/styles.css" />
    <script type="importmap">
    {
        "imports": {
            "lit": "/js/lit-bundle.min.js",
            "lit-html": "/js/lit-bundle.min.js",
            "lit-element": "/js/lit-bundle.min.js",
            "@lit/reactive-element": "/js/lit-bundle.min.js"
        }
    }
    </script>
    <script type="module" src="/js/components/item-grid.js"></script>
    <script type="module" src="/js/components/nav-bar.js"></script>
</head>
<body style="background:var(--bg, #faf9f7)">
  <nav-bar api-base="<%= apiBase %>" current-user="<%= user ? JSON.stringify(user) : '' %>"></nav-bar>
  
  <div class="hero">
    <p style="font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;color:#c9a96e;margin-bottom:12px;font-weight:600">
      Rare · Curated · Collectible
    </p>
    <h1>The Collector's<br>Marketplace</h1>
    <p>Discover rare items. Make offers. Trade with confidence.</p>
  </div>

  <main>
    <item-grid api-base="<%= apiBase %>"></item-grid>
  </main>
</body>
</html>
